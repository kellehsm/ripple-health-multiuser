{
  "expo": {
    "name": "Ripple Wellness",
    "slug": "ripple-health",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "wellnessfresh",
    "userInterfaceStyle": "automatic",
    "ios": {
      "infoPlist": {
        "NSCameraUsageDescription": "Camera is used to scan food barcodes for meal logging."
      }
    },
    "android": {
      "package": "com.kellehs.wellness",
      "adaptiveIcon": {
        "backgroundColor": "#FBFAF7",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.health.READ_STEPS",
        "android.permission.health.READ_SLEEP",
        "android.permission.health.READ_HEART_RATE",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_HEALTH"
      ]
    },
    "plugins": [
      "expo-health-connect",
      "expo-notifications",
      "./plugins/withForegroundServiceType",
      "./plugins/withAndroidWidget",
      "./plugins/withAndroidShortcuts",
      [
        "expo-network-security-config",
        {
          "networkSecurityConfigPath": "./assets/network_security_config.xml"
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 36,
            "targetSdkVersion": 36,
            "minSdkVersion": 26,
            "kotlinVersion": "2.1.20"
          }
        }
      ],
      "expo-sqlite",
      "expo-secure-store"
    ],
    "updates": {
      "url": "https://u.expo.dev/db5bae1a-d8dd-4c26-84e7-7711669de2e8",
      "enabled": true,
      "fallbackToCacheTimeout": 0
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "web": {
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "db5bae1a-d8dd-4c26-84e7-7711669de2e8"
      }
    },
    "owner": "kels_gg"
  }
}
